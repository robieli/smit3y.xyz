---
const emailAddress = "ssamsmit@umich.edu";
---

<footer class="site-footer" aria-label="Site footer">
  <p>&copy; 2026 smit3y.xyz - Built by Samuel Smith</p>
  <nav class="footer-links" aria-label="Footer links">
    <a
      href="https://www.linkedin.com/in/ssam-smith/"
      target="_blank"
      rel="noopener noreferrer me"
    >
      LinkedIn
    </a>
    <button
      type="button"
      class="copy-email-button email-link"
      data-email={emailAddress}
      aria-label={`Copy ${emailAddress} to clipboard`}
    >
      Email
    </button>
  </nav>
  <div class="copy-toast" role="status" aria-live="polite" aria-atomic="true">
    Email copied
  </div>
</footer>

<script>
  const copyButton = document.querySelector(".copy-email-button");
  const copyToast = document.querySelector(".copy-toast");
  let toastTimeout: number | undefined;

  const showToast = (message: string) => {
    if (!copyToast) return;
    copyToast.textContent = message;
    copyToast.classList.add("is-visible");

    window.clearTimeout(toastTimeout);
    toastTimeout = window.setTimeout(() => {
      copyToast.classList.remove("is-visible");
    }, 1800);
  };

  copyButton?.addEventListener("click", async () => {
    const email = copyButton.getAttribute("data-email");
    if (!email) return;

    try {
      await navigator.clipboard.writeText(email);
      showToast("Email copied");
    } catch {
      showToast("Copy failed");
    }
  });
</script>
