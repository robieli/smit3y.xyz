---
export interface Props {
  size?: number;
  lineCount?: number;
  color?: string;
  backOpacityPct?: number;
  autoSpin?: boolean;
  tiltXDeg?: number;
  tiltZDeg?: number;
}

const {
  size = 140,
  lineCount = 12,
  color = "#378ADD",
  backOpacityPct = 22,
  autoSpin = true,
  tiltXDeg = 0,
  tiltZDeg = 0,
} = Astro.props;
---

<div id="globe-wrap">
  <canvas id="globe-canvas"></canvas>
</div>

<style>
  #globe-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    padding: 2rem 0;
    font-family: inherit;
  }

  #globe-canvas {
    cursor: grab;
    display: block;
  }

  #globe-canvas:active {
    cursor: grabbing;
  }
</style>

<script
  define:vars={{
    size,
    lineCount,
    color,
    backOpacityPct,
    autoSpin,
    tiltXDeg,
    tiltZDeg,
  }}
>
  // ---------------------------------------------------------------------------
  // Constants
  // ---------------------------------------------------------------------------
  const CANVAS_SIZE = Math.max(420, Math.round(size * 2.4));
  const ARC_STEPS = 120; // points per arc segment
  const FRONT_ALPHA = 0.9;
  const FRONT_LINE_WIDTH = 1.1;
  const BACK_LINE_WIDTH = 0.7;
  const SPIN_SPEED = 0.005333333; // radians per frame at 60fps

  // ---------------------------------------------------------------------------
  // State
  // ---------------------------------------------------------------------------
  let radius = size;
  let segments = lineCount;
  let lineColor = color;
  let backOpacity = (backOpacityPct / 100) * FRONT_ALPHA;

  let rotY = 0.5; // longitude spin (around vertical Y axis)
  let tiltX = (tiltXDeg * Math.PI) / 180; // tip forward/back (around X axis)
  let tiltZ = (tiltZDeg * Math.PI) / 180; // roll left/right (around Z axis)

  let isSpinning = autoSpin;
  let isDragging = false;
  let lastPointerX = 0;
  let rafId = null;
  let lastTimestamp = null;

  // Cached per-frame trig values — recomputed once per draw call
  let cosRotY = 0,
    sinRotY = 0;
  let cosTiltX = 0,
    sinTiltX = 0;
  let cosTiltZ = 0,
    sinTiltZ = 0;

  // Cached RGB components — recomputed only when lineColor changes
  let colorR = 0,
    colorG = 0,
    colorB = 0;

  // ---------------------------------------------------------------------------
  // DOM refs
  // ---------------------------------------------------------------------------
  const canvas = document.getElementById("globe-canvas");
  const ctx = canvas.getContext("2d");
  canvas.width = CANVAS_SIZE;
  canvas.height = CANVAS_SIZE;

  // ---------------------------------------------------------------------------
  // Helpers
  // ---------------------------------------------------------------------------

  /** Parse a hex color string into cached r/g/b integers. */
  function parseColor(hex) {
    colorR = parseInt(hex.slice(1, 3), 16);
    colorG = parseInt(hex.slice(3, 5), 16);
    colorB = parseInt(hex.slice(5, 7), 16);
  }

  /** Cache all trig values used by rotatePoint this frame. */
  function cacheTrig() {
    cosRotY = Math.cos(rotY);
    sinRotY = Math.sin(rotY);
    cosTiltX = Math.cos(tiltX);
    sinTiltX = Math.sin(tiltX);
    cosTiltZ = Math.cos(tiltZ);
    sinTiltZ = Math.sin(tiltZ);
  }

  /**
   * Transform a spherical (lat, lon) coordinate into a projected canvas point.
   * Uses cached trig — must call cacheTrig() once before a batch of these.
   *
   * Coordinate system: Y-up, so poles sit at canvas top/bottom.
   * Rotation order: spin around Y → tilt around X → roll around Z.
   *
   * @param {number} lat  latitude in radians [-π/2, π/2]
   * @param {number} lon  longitude in radians [0, 2π]
   * @returns {{ x: number, y: number, z: number }}
   */
  function rotatePoint(lat, lon) {
    // Spherical → Cartesian (Y-up)
    const x0 = Math.cos(lat) * Math.sin(lon);
    const y0 = Math.sin(lat);
    const z0 = Math.cos(lat) * Math.cos(lon);

    // Spin around Y axis (longitude rotation, driven by autoSpin / drag)
    const x1 = x0 * cosRotY + z0 * sinRotY;
    const y1 = y0;
    const z1 = -x0 * sinRotY + z0 * cosRotY;

    // Tilt around X axis (fixed pitch)
    const x2 = x1;
    const y2 = y1 * cosTiltX - z1 * sinTiltX;
    const z2 = y1 * sinTiltX + z1 * cosTiltX;

    // Roll around Z axis (Tilt Z slider)
    const x3 = x2 * cosTiltZ - y2 * sinTiltZ;
    const y3 = x2 * sinTiltZ + y2 * cosTiltZ;
    const z3 = z2;

    return { x: x3 * radius, y: -y3 * radius, z: z3 * radius };
  }

  /**
   * Draw one polyline split into back (z < 0) and front (z ≥ 0) segments,
   * so back opacity is applied per-point rather than per-line.
   *
   * Callers are responsible for setting ctx.strokeStyle / lineWidth before
   * calling this; here we only manage moveTo / lineTo / stroke.
   */
  function drawSplitPolyline(points) {
    // Back pass
    ctx.beginPath();
    ctx.strokeStyle = `rgba(${colorR},${colorG},${colorB},${backOpacity})`;
    ctx.lineWidth = BACK_LINE_WIDTH;
    let isDrawing = false;
    for (const p of points) {
      if (p.z < 0) {
        if (!isDrawing) {
          ctx.moveTo(p.x, p.y);
          isDrawing = true;
        } else ctx.lineTo(p.x, p.y);
      } else {
        isDrawing = false;
      }
    }
    ctx.stroke();

    // Front pass
    ctx.beginPath();
    ctx.strokeStyle = `rgba(${colorR},${colorG},${colorB},${FRONT_ALPHA})`;
    ctx.lineWidth = FRONT_LINE_WIDTH;
    isDrawing = false;
    for (const p of points) {
      if (p.z >= 0) {
        if (!isDrawing) {
          ctx.moveTo(p.x, p.y);
          isDrawing = true;
        } else ctx.lineTo(p.x, p.y);
      } else {
        isDrawing = false;
      }
    }
    ctx.stroke();
  }

  // ---------------------------------------------------------------------------
  // Draw
  // ---------------------------------------------------------------------------

  function draw(timestamp) {
    if (isSpinning && !isDragging) {
      const delta =
        lastTimestamp != null ? (timestamp - lastTimestamp) / 1000 : 0;
      rotY += SPIN_SPEED * delta * 60; // normalize to 60fps equivalent
    }
    lastTimestamp = timestamp;

    ctx.clearRect(0, 0, CANVAS_SIZE, CANVAS_SIZE);
    ctx.save();
    ctx.translate(CANVAS_SIZE / 2, CANVAS_SIZE / 2);

    cacheTrig();

    const lonLineCount = segments * 2;

    // Latitude rings
    for (let i = 1; i < segments; i++) {
      const lat = -Math.PI / 2 + (Math.PI / segments) * i;
      const points = [];
      for (let j = 0; j <= ARC_STEPS; j++) {
        points.push(rotatePoint(lat, ((2 * Math.PI) / ARC_STEPS) * j));
      }
      drawSplitPolyline(points);
    }

    // Longitude arcs
    for (let j = 0; j < lonLineCount; j++) {
      const lon = ((2 * Math.PI) / lonLineCount) * j;
      const points = [];
      for (let i = 0; i <= ARC_STEPS; i++) {
        points.push(rotatePoint(-Math.PI / 2 + (Math.PI / ARC_STEPS) * i, lon));
      }
      drawSplitPolyline(points);
    }

    ctx.restore();
    rafId = requestAnimationFrame(draw);
  }

  // ---------------------------------------------------------------------------
  // Input handling
  // ---------------------------------------------------------------------------

  function onPointerDown(x, _y) {
    isDragging = true;
    lastPointerX = x;
  }

  function onPointerMove(x, _y) {
    if (!isDragging) return;
    rotY += (x - lastPointerX) * 0.01;
    lastPointerX = x;
  }

  function onPointerUp() {
    isDragging = false;
  }

  canvas.addEventListener("mousedown", (e) =>
    onPointerDown(e.clientX, e.clientY),
  );
  canvas.addEventListener("mousemove", (e) =>
    onPointerMove(e.clientX, e.clientY),
  );
  canvas.addEventListener("mouseup", onPointerUp);
  canvas.addEventListener("mouseleave", onPointerUp);

  canvas.addEventListener(
    "touchstart",
    (e) => {
      e.preventDefault();
      onPointerDown(e.touches[0].clientX, e.touches[0].clientY);
    },
    { passive: false },
  );
  canvas.addEventListener(
    "touchmove",
    (e) => {
      e.preventDefault();
      onPointerMove(e.touches[0].clientX, e.touches[0].clientY);
    },
    { passive: false },
  );
  canvas.addEventListener("touchend", onPointerUp);

  // ---------------------------------------------------------------------------
  // ---------------------------------------------------------------------------
  // Init
  // ---------------------------------------------------------------------------
  parseColor(lineColor);
  rafId = requestAnimationFrame(draw);

  // Cleanup on Astro view transitions or component unmount
  document.addEventListener(
    "astro:before-swap",
    () => {
      cancelAnimationFrame(rafId);
    },
    { once: true },
  );
</script>
