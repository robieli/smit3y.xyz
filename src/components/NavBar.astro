---
import { fallbackItems } from "../lib/ticker/fallback";
const tickerItems = fallbackItems;
---

<div class="site-chrome">
  <header class="site-header" aria-label="Site header">
    <a class="brand-mark" href="/#home" aria-label="smit3y.xyz home">
      <span class="brand-icon" aria-hidden="true">S3</span>
      <span>smit3y.xyz</span>
    </a>
    <nav class="site-nav" aria-label="Primary navigation">
      <a class="is-active" href="/#home" aria-current="page">Home</a>
      <a href="/#about">About</a>
      <a href="/#research">Research</a>
      <a href="/#experience">Experience</a>
      <a href="/#sny">S&amp;Y</a>
      <div class="nav-controls">
        <button class="theme-toggle" type="button" aria-label="Toggle light/dark theme">
          <svg class="theme-icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="5"></circle>
            <line x1="12" y1="1" x2="12" y2="3"></line>
            <line x1="12" y1="21" x2="12" y2="23"></line>
            <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
            <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
            <line x1="1" y1="12" x2="3" y2="12"></line>
            <line x1="21" y1="12" x2="23" y2="12"></line>
            <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
            <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
          </svg>
          <svg class="theme-icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
          </svg>
        </button>
        <div class="palette-menu">
          <button class="palette-toggle" type="button" aria-label="Choose color theme" aria-expanded="false" aria-haspopup="menu">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="13.5" cy="6.5" r=".5" fill="currentColor"></circle>
              <circle cx="17.5" cy="10.5" r=".5" fill="currentColor"></circle>
              <circle cx="8.5" cy="7.5" r=".5" fill="currentColor"></circle>
              <circle cx="6.5" cy="12.5" r=".5" fill="currentColor"></circle>
              <path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.926 0 1.648-.746 1.648-1.688 0-.437-.18-.835-.437-1.125-.29-.289-.438-.652-.438-1.125a1.64 1.64 0 0 1 1.668-1.668h1.996c3.051 0 5.555-2.503 5.555-5.554C21.965 6.012 17.461 2 12 2z"></path>
            </svg>
          </button>
          <div class="palette-popover" role="menu" aria-label="Color themes" hidden>
            <button class="palette-option" type="button" role="menuitemradio" data-palette-choice="midnight" aria-checked="true">
              <span class="palette-swatch palette-swatch-midnight" aria-hidden="true"></span>
              <span class="palette-option-name">Midnight</span>
              <svg class="palette-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>
            </button>
            <button class="palette-option" type="button" role="menuitemradio" data-palette-choice="solar" aria-checked="false">
              <span class="palette-swatch palette-swatch-solar" aria-hidden="true"></span>
              <span class="palette-option-name">Solar</span>
              <svg class="palette-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>
            </button>
            <button class="palette-option" type="button" role="menuitemradio" data-palette-choice="forest" aria-checked="false">
              <span class="palette-swatch palette-swatch-forest" aria-hidden="true"></span>
              <span class="palette-option-name">Forest</span>
              <svg class="palette-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>
            </button>
            <button class="palette-option" type="button" role="menuitemradio" data-palette-choice="crimson" aria-checked="false">
              <span class="palette-swatch palette-swatch-crimson" aria-hidden="true"></span>
              <span class="palette-option-name">Crimson</span>
              <svg class="palette-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>
            </button>
            <button class="palette-option" type="button" role="menuitemradio" data-palette-choice="mono" aria-checked="false">
              <span class="palette-swatch palette-swatch-mono" aria-hidden="true"></span>
              <span class="palette-option-name">Mono</span>
              <svg class="palette-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>
            </button>
            <div class="palette-divider" role="separator"></div>
            <button class="palette-option" type="button" role="menuitemradio" data-palette-choice="custom" aria-checked="false">
              <span class="palette-swatch palette-swatch-custom" aria-hidden="true"></span>
              <span class="palette-option-name">Custom</span>
              <svg class="palette-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>
            </button>
            <div class="palette-custom-panel" hidden>
              <label><span>Accent</span><input type="color" data-custom-var="accent" value="#8b5cf6"/></label>
              <label><span>G1</span><input type="color" data-custom-var="g1" value="#8791ff"/></label>
              <label><span>G2</span><input type="color" data-custom-var="g2" value="#5ea1f2"/></label>
              <label><span>G3</span><input type="color" data-custom-var="g3" value="#17bfd1"/></label>
            </div>
          </div>
        </div>
      </div>
    </nav>
  </header>
  <div class="market-ticker" aria-label="Market ticker">
    <div class="market-ticker-track">
      {
        [...tickerItems, ...tickerItems].map((item) => (
          <span class="market-ticker-item" data-symbol={item.symbol}>
            <span class="market-symbol">{item.symbol}</span>
            <span class="market-price">{item.price}</span>
            <span class:list={["market-change", item.isNegative && "is-negative"]}>
              {item.change}
            </span>
          </span>
        ))
      }
    </div>
  </div>
</div>
<nav class="section-dots" aria-label="Section progress">
  <a class="is-active" href="/#home" aria-label="Home" aria-current="page"></a>
  <a href="/#about" aria-label="About"></a>
  <a href="/#research" aria-label="Research"></a>
  <a href="/#experience" aria-label="Experience"></a>
  <a href="/#sny" aria-label="S and Y"></a>
</nav>

<script>
  const navLinks = Array.from(
    document.querySelectorAll<HTMLAnchorElement>(".site-nav a"),
  );
  const dotLinks = Array.from(
    document.querySelectorAll<HTMLAnchorElement>(".section-dots a"),
  );
  const sectionLinks = [...navLinks, ...dotLinks];

  const setActiveSection = (id: string) => {
    for (const link of sectionLinks) {
      const isActive = link.hash === `#${id}`;
      link.classList.toggle("is-active", isActive);

      if (isActive) {
        link.setAttribute("aria-current", "page");
      } else {
        link.removeAttribute("aria-current");
      }
    }
  };

  for (const link of sectionLinks) {
    link.addEventListener("click", () => {
      const id = link.hash.slice(1);
      if (id) setActiveSection(id);
    });
  }

  const sectionTargets = navLinks
    .map((link) => document.querySelector<HTMLElement>(link.hash))
    .filter((section): section is HTMLElement => section !== null);

  const updateActiveSectionFromScroll = () => {
    if (sectionTargets.length === 0) return;

    const marker = window.innerHeight * 0.42;
    let activeSection = sectionTargets[0];

    for (let index = sectionTargets.length - 1; index >= 0; index -= 1) {
      const section = sectionTargets[index];
      const rect = section.getBoundingClientRect();

      if (rect.top <= marker) {
        activeSection = section;
        break;
      }
    }

    setActiveSection(activeSection.id);
  };

  let scrollFrame = 0;
  window.addEventListener(
    "scroll",
    () => {
      window.cancelAnimationFrame(scrollFrame);
      scrollFrame = window.requestAnimationFrame(updateActiveSectionFromScroll);
    },
    { passive: true },
  );

  window.addEventListener("resize", updateActiveSectionFromScroll);

  if ("fonts" in document) {
    document.fonts.ready.then(updateActiveSectionFromScroll);
  } else {
    updateActiveSectionFromScroll();
  }

  const themeToggle = document.querySelector<HTMLButtonElement>(".theme-toggle");
  themeToggle?.addEventListener("click", () => {
    const html = document.documentElement;
    const isLight = html.getAttribute("data-theme") === "light";
    const next = isLight ? "dark" : "light";
    if (next === "dark") {
      html.removeAttribute("data-theme");
    } else {
      html.setAttribute("data-theme", next);
    }
    localStorage.setItem("theme", next);
  });
</script>

<script>
  interface TickerItem {
    symbol: string;
    price: string;
    change: string;
    isNegative: boolean;
  }

  async function refreshTicker() {
    try {
      const res = await fetch("/api/ticker");
      if (!res.ok) return;
      const { data: items }: { data: TickerItem[] } = await res.json();

      const allItems = document.querySelectorAll<HTMLSpanElement>(
        ".market-ticker-item",
      );
      const count = items.length;

      for (let i = 0; i < allItems.length; i++) {
        const item = items[i % count];
        const el = allItems[i];
        const priceEl = el.querySelector<HTMLSpanElement>(".market-price");
        const changeEl = el.querySelector<HTMLSpanElement>(".market-change");

        if (priceEl) priceEl.textContent = item.price;
        if (changeEl) {
          changeEl.textContent = item.change;
          changeEl.classList.toggle("is-negative", item.isNegative);
        }
      }
    } catch {
      // silently keep fallback data
    }
  }

  refreshTicker();
</script>

<script>
  const PALETTES = ["midnight", "solar", "forest", "crimson", "mono"] as const;
  type Palette = (typeof PALETTES)[number] | "custom";
  type CustomColors = { accent: string; g1: string; g2: string; g3: string };

  const root = document.documentElement;
  const CUSTOM_VARS = [
    "--accent",
    "--accent-light",
    "--accent-lighter",
    "--accent-blue",
    "--g1",
    "--g2",
    "--g3",
    "--gradient-hero",
    "--gradient-timeline",
    "--glow-1",
    "--glow-2",
    "--glow-3",
    "--glow-4",
    "--glow-5",
    "--glow-6",
    "--glow-7",
    "--border-img",
    "--shadow-tag",
    "--text-nav-hover",
    "--text-hover-tag",
    "--c-accent",
    "--c-g1",
    "--c-g2",
    "--c-g3",
  ];

  function applyPaletteAttribute(name: Palette) {
    if (name === "midnight") {
      root.removeAttribute("data-palette");
    } else {
      root.setAttribute("data-palette", name);
    }
  }

  function clearCustomInlineStyles() {
    for (const v of CUSTOM_VARS) root.style.removeProperty(v);
  }

  function applyCustomColors(colors: CustomColors) {
    const s = root.style;
    s.setProperty("--c-accent", colors.accent);
    s.setProperty("--c-g1", colors.g1);
    s.setProperty("--c-g2", colors.g2);
    s.setProperty("--c-g3", colors.g3);
  }

  function readCustom(): CustomColors {
    try {
      const raw = localStorage.getItem("custom-palette");
      if (!raw) throw new Error("no custom palette");
      const parsed = JSON.parse(raw) as Partial<CustomColors>;
      if (!parsed.accent || !parsed.g1 || !parsed.g2 || !parsed.g3) {
        throw new Error("incomplete");
      }
      return {
        accent: parsed.accent,
        g1: parsed.g1,
        g2: parsed.g2,
        g3: parsed.g3,
      };
    } catch {
      return { accent: "#8b5cf6", g1: "#8791ff", g2: "#5ea1f2", g3: "#17bfd1" };
    }
  }

  const paletteToggle = document.querySelector<HTMLButtonElement>(".palette-toggle");
  const palettePopover = document.querySelector<HTMLDivElement>(".palette-popover");
  const paletteOptions = Array.from(
    document.querySelectorAll<HTMLButtonElement>("[data-palette-choice]"),
  );
  const customPanel = document.querySelector<HTMLDivElement>(".palette-custom-panel");
  const customInputs = Array.from(
    document.querySelectorAll<HTMLInputElement>(".palette-custom-panel input[type='color']"),
  );

  function openPopover() {
    if (!palettePopover || !paletteToggle) return;
    palettePopover.hidden = false;
    requestAnimationFrame(() => {
      palettePopover.classList.add("is-open");
    });
    paletteToggle.setAttribute("aria-expanded", "true");
  }

  function closePopover() {
    if (!palettePopover || !paletteToggle) return;
    palettePopover.classList.remove("is-open");
    paletteToggle.setAttribute("aria-expanded", "false");
    const handle = (e: TransitionEvent) => {
      if (e.propertyName !== "opacity") return;
      palettePopover.hidden = true;
      palettePopover.removeEventListener("transitionend", handle);
    };
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
      palettePopover.hidden = true;
    } else {
      palettePopover.addEventListener("transitionend", handle);
    }
  }

  function syncChecked(name: Palette) {
    for (const btn of paletteOptions) {
      const choice = btn.dataset.paletteChoice as Palette;
      btn.setAttribute("aria-checked", choice === name ? "true" : "false");
    }
    if (customPanel) customPanel.hidden = name !== "custom";
  }

  function syncCustomInputs(colors: CustomColors) {
    for (const input of customInputs) {
      const key = input.dataset.customVar as keyof CustomColors | undefined;
      if (key && colors[key]) input.value = colors[key];
    }
  }

  function selectPalette(name: Palette) {
    clearCustomInlineStyles();
    if (name === "custom") {
      const colors = readCustom();
      applyPaletteAttribute("custom");
      applyCustomColors(colors);
      localStorage.setItem("palette", "custom");
      localStorage.setItem("custom-palette", JSON.stringify(colors));
      syncCustomInputs(colors);
    } else {
      applyPaletteAttribute(name);
      localStorage.setItem("palette", name);
    }
    syncChecked(name);
  }

  paletteToggle?.addEventListener("click", (e) => {
    e.stopPropagation();
    const expanded = paletteToggle.getAttribute("aria-expanded") === "true";
    if (expanded) closePopover();
    else openPopover();
  });

  paletteToggle?.addEventListener("keydown", (e) => {
    if (e.key === "ArrowDown" || e.key === "Enter" || e.key === " ") {
      e.preventDefault();
      openPopover();
      const first = paletteOptions[0];
      first?.focus();
    }
  });

  document.addEventListener("click", (e) => {
    if (!palettePopover || !palettePopover.classList.contains("is-open")) return;
    if (
      !palettePopover.contains(e.target as Node) &&
      e.target !== paletteToggle &&
      !paletteToggle?.contains(e.target as Node)
    ) {
      closePopover();
    }
  });

  document.addEventListener("keydown", (e) => {
    if (e.key !== "Escape") return;
    if (!palettePopover || !palettePopover.classList.contains("is-open")) return;
    e.preventDefault();
    closePopover();
    paletteToggle?.focus();
  });

  for (const btn of paletteOptions) {
    btn.addEventListener("click", () => {
      const choice = btn.dataset.paletteChoice as Palette | undefined;
      if (!choice) return;
      selectPalette(choice);
    });
    btn.addEventListener("keydown", (e) => {
      const idx = paletteOptions.indexOf(btn);
      if (e.key === "ArrowDown") {
        e.preventDefault();
        paletteOptions[(idx + 1) % paletteOptions.length]?.focus();
      } else if (e.key === "ArrowUp") {
        e.preventDefault();
        paletteOptions[(idx - 1 + paletteOptions.length) % paletteOptions.length]?.focus();
      } else if (e.key === "Home") {
        e.preventDefault();
        paletteOptions[0]?.focus();
      } else if (e.key === "End") {
        e.preventDefault();
        paletteOptions[paletteOptions.length - 1]?.focus();
      }
    });
  }

  for (const input of customInputs) {
    input.addEventListener("input", () => {
      const key = input.dataset.customVar as keyof CustomColors | undefined;
      if (!key) return;
      const colors = readCustom();
      colors[key] = input.value;
      localStorage.setItem("custom-palette", JSON.stringify(colors));
      applyCustomColors(colors);
    });
  }

  // Initial UI sync (the palette attribute + inline styles are already
  // applied by the no-flash script in BaseLayout.astro).
  const initialPalette = (localStorage.getItem("palette") || "midnight") as Palette;
  syncChecked(initialPalette);
  if (initialPalette === "custom") syncCustomInputs(readCustom());
</script>
