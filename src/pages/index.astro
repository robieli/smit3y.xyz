---
import BaseLayout from "../layouts/BaseLayout.astro";
import { loadResearchEntries } from "../lib/research";
import smit3yImage from "../assets/smit3y.jpg";

const researchEntries = loadResearchEntries();
const featuredResearchEntries = researchEntries.slice(0, 6);
const experienceEntries = [
  {
    period: "SUMMER 2025",
    role: "Wealth Management Intern",
    organization: "Local Wealth Management Firm - San Diego, CA",
    bullets: [
      "Assisted in portfolio construction and client advisory across equity and fixed-income allocations",
      "Conducted market research and financial analysis to support investment recommendations",
      "Gained hands-on experience with institutional trading platforms and client relationship management",
    ],
  },
  {
    period: "2023 - PRESENT",
    role: "Practice Player",
    organization: "University of Michigan Women's Basketball",
    bullets: [
      "Selected as a practice player to train with Division I athletes, developing team-oriented discipline",
      "Contributed to game preparation through simulation of opponent strategies and play execution",
    ],
  },
  {
    period: "2023 - PRESENT",
    role: "Co-Founder",
    organization: "S&Y Scholars - College Consulting",
    bullets: [
      "Co-founded a peer-to-peer college admissions consulting service helping families navigate recruitment and strategy",
      "Provided essay editing, interview prep, and application strategy to high school students",
      "Winner of the 2023 New York Times College Essay Challenge",
    ],
  },
  {
    period: "ONGOING",
    role: "Independent Equity Research Analyst",
    organization: "Self-Directed Research",
    bullets: [
      "Published investment theses covering crypto mining, SaaS, DeFi, and semiconductor sectors",
      "Built financial models (DCF, comps, scenario analysis) for public equities and digital assets",
      "Participated in the 2026 Perplexity Computer Student Stock Pitch Competition with a long thesis",
    ],
  },
];
const snyStats = [
  { value: "37", label: "Schools Applied" },
  { value: "75%+", label: "Success Rate" },
  { value: "1570", label: "Combined SAT" },
  { value: "4.7", label: "Combined GPA" },
];
const snyServices = [
  {
    title: "Interview & Resume Guidance",
    description:
      "Real-time consultation leveraging our personal experiences. Personalized strategy tailored to each student's aspirations.",
    icon: "microphone",
  },
  {
    title: "Essay Editing",
    description:
      "Refining application essays to showcase your unique strengths. We translate your voice directly onto paper.",
    icon: "pen",
  },
  {
    title: "Application Strategy",
    description:
      "Expert advice on school selection, timelines, and standing out. We applied to 37 schools between us.",
    icon: "target",
  },
];
const snyFounders = [
  {
    name: "Samuel Smith",
    school: "University of Michigan - Economics & Psychology",
    bio: "Junior at U of M, practice player on the Women's Basketball team, avid chess player, and winner of the 2023 New York Times College Essay Challenge. Currently interning at a local wealth management firm in San Diego.",
  },
  {
    name: "Richard Yoon",
    school: "Columbia University - Dual Degree with Sciences Po",
    bio: "Junior at Columbia, spent first two years in Reims, France through the dual-degree program. Avid basketball player, 10+ years of robotics experience, and former Co-President of Mock Trial at La Jolla High.",
  },
];
---

<BaseLayout title="smit3y.xyz" fullBleed={true}>
  <section class="landing-screen" aria-label="Smit3y landing page">
    <div class="landing-content">
      <h1 class="landing-title">SMIT3Y</h1>
      <div class="landing-rule" aria-hidden="true"></div>
      <p class="landing-primary">
        EQUITY RESEARCH <span aria-hidden="true">·</span> CRYPTO INFRASTRUCTURE
        <span aria-hidden="true">·</span> FINANCIAL ANALYSIS
      </p>
      <p class="landing-secondary">
        UNIVERSITY OF MICHIGAN <span aria-hidden="true">·</span> ECONOMICS & PSYCHOLOGY
      </p>
      <button class="landing-enter" type="button" aria-label="Enter smit3y.xyz">
        ENTER <span aria-hidden="true">→</span>
      </button>
    </div>
  </section>
  <section id="home" class="home-section" aria-label="Home">
    <div class="hero-content">
      <p class="hero-kicker">
        EQUITY RESEARCH <span aria-hidden="true">·</span> CRYPTO INFRASTRUCTURE
      </p>
      <h1 class="hero-title">SMIT3Y</h1>
      <p class="hero-subtitle">
        FINANCIAL ANALYSIS <span aria-hidden="true">·</span> UNIVERSITY OF MICHIGAN
      </p>
      <div class="hero-actions" aria-label="Featured actions">
        <a class="hero-action hero-action-primary" href="#research">
          VIEW RESEARCH <span aria-hidden="true">→</span>
        </a>
        <a class="hero-action hero-action-secondary" href="#about">ABOUT ME</a>
      </div>
    </div>
    <a class="scroll-cue" href="#about" aria-label="Scroll to about section">
      <span>SCROLL TO EXPLORE</span>
      <span aria-hidden="true">⌄</span>
    </a>
  </section>
  <section id="about" class="about-section" aria-label="About">
    <div class="about-shell">
      <p class="about-kicker">// ABOUT</p>
      <h2 class="about-title">Who I Am</h2>
      <div class="about-content">
        <div class="about-image-wrapper">
          <img src={smit3yImage.src} alt="Eli Robinson" class="about-image" />
        </div>
        <div class="about-text">
          <p class="about-paragraph about-paragraph-lead">
            Samuel Andres Smith is an incoming senior at the University of
            Michigan who writes, researches, and builds at the intersection of
            digital assets and traditional finance. Currently a Sales, Trading,
            and Prime Brokerage intern at Coinbase, he produces investor-focused
            equity and tokenomic reports while mentoring peers through SNY
            Scholars — a student-led program helping families navigate college
            recruitment.
          </p>
          <p class="about-paragraph">
            Samuel combines rigorous market analysis with a student’s
            perspective to break down the most pivotal intersection of our
            generation, AI and crypto. You can also catch Samuel in the gym,
            playing basketball, or attempting to learn the electric guitar.
          </p>
          <div class="about-tags" aria-label="Focus areas">
            <span>Equity Research</span>
            <span>Bitcoin Mining</span>
            <span>DeFi & Blockchain</span>
            <span>SaaS Valuations</span>
            <span>Financial Modeling</span>
            <span>Quantitative Finance</span>
          </div>
        </div>
      </div>
    </div>
  </section>
  <section id="research" class="research-section" aria-label="Research">
    <div class="research-header">
      <p class="section-kicker">// RESEARCH</p>
      <h2>Investment Theses</h2>
      <p>
        My research portfolio spans equity analyses and tokenomic studies
        written through an investor lens. I attempt to combine market data,
        trends I see coming to fruition in my lifetime, and academic literature
        to produce concise reports that inform investment decisions and
        classroom learning — aimed at peers, funders, and practitioners seeking
        clear, actionable analysis. I spend many nights and weekends researching
        the next best beneficiary of our AI boom. You can find some of these
        beneficiaries below.
      </p>
    </div>
    <div class="research-grid">
      {
        featuredResearchEntries.map((entry) => (
          <a class="research-card" href={`/research/${entry.slug}`}>
            <span class="research-card-label">
              {entry.stockLabel || entry.title.split(" ")[0]}
            </span>
            <span class="research-card-title">{entry.title}</span>
            {entry.summary && (
              <span class="research-card-summary">{entry.summary}</span>
            )}
            <span class="research-card-arrow" aria-hidden="true">
              →
            </span>
          </a>
        ))
      }
    </div>
    <div class="research-actions">
      <a class="research-see-all" href="/research">See All</a>
    </div>
  </section>
  <section id="experience" class="experience-section" aria-label="Experience">
    <div class="experience-shell">
      <div class="experience-header">
        <p class="section-kicker">// EXPERIENCE</p>
        <h2>Where I've Worked</h2>
      </div>
      <div class="experience-timeline">
        {
          experienceEntries.map((entry) => (
            <article class="experience-item">
              <p class="experience-period">{entry.period}</p>
              <h3 class="experience-role">{entry.role}</h3>
              <p class="experience-organization">{entry.organization}</p>
              <ul class="experience-points">
                {entry.bullets.map((point) => (
                  <li>{point}</li>
                ))}
              </ul>
            </article>
          ))
        }
      </div>
    </div>
  </section>
  <section id="sny" class="sny-section" aria-label="S and Y Scholars">
    <div class="sny-shell">
      <header class="sny-header">
        <h2>S&amp;Y Scholars</h2>
        <p>
          Guidance from students who were in your shoes yesterday. Peer-to-peer
          college admissions consulting.
        </p>
      </header>

      <div class="sny-stats" aria-label="S and Y Scholars results">
        {
          snyStats.map((stat) => (
            <article class="sny-stat-card">
              <p class="sny-stat-value">{stat.value}</p>
              <p class="sny-stat-label">{stat.label}</p>
            </article>
          ))
        }
      </div>

      <div class="sny-services">
        <p class="section-kicker">// SERVICES</p>
        <h3>What We Offer</h3>
        <div class="sny-services-grid">
          {
            snyServices.map((service) => (
              <article class="sny-service-card">
                <span class="sny-service-icon" aria-hidden="true">
                  {service.icon === "microphone" && (
                    <svg viewBox="0 0 24 24" fill="none" focusable="false">
                      <path
                        d="M12 3a3 3 0 0 1 3 3v5a3 3 0 1 1-6 0V6a3 3 0 0 1 3-3Z"
                        stroke="currentColor"
                        stroke-width="1.8"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      ></path>
                      <path
                        d="M6.5 10.5a5.5 5.5 0 0 0 11 0M12 16v4M9 20h6"
                        stroke="currentColor"
                        stroke-width="1.8"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      ></path>
                    </svg>
                  )}
                  {service.icon === "pen" && (
                    <svg viewBox="0 0 24 24" fill="none" focusable="false">
                      <path
                        d="m4 20 4-1 10-10-3-3L5 16l-1 4Z"
                        stroke="currentColor"
                        stroke-width="1.8"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      ></path>
                      <path
                        d="m13 6 3 3M4 20l4-4"
                        stroke="currentColor"
                        stroke-width="1.8"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      ></path>
                    </svg>
                  )}
                  {service.icon === "target" && (
                    <svg viewBox="0 0 24 24" fill="none" focusable="false">
                      <circle
                        cx="12"
                        cy="12"
                        r="8"
                        stroke="currentColor"
                        stroke-width="1.8"
                      ></circle>
                      <circle
                        cx="12"
                        cy="12"
                        r="4"
                        stroke="currentColor"
                        stroke-width="1.8"
                      ></circle>
                      <circle cx="12" cy="12" r="1.2" fill="currentColor"></circle>
                    </svg>
                  )}
                </span>
                <h4>{service.title}</h4>
                <p>{service.description}</p>
              </article>
            ))
          }
        </div>
      </div>

      <div class="sny-team">
        <p class="section-kicker">// TEAM</p>
        <h3>Meet the Founders</h3>
        <div class="sny-founders-grid">
          {
            snyFounders.map((founder) => (
              <article class="sny-founder-card">
                <h4>{founder.name}</h4>
                <p class="sny-founder-school">{founder.school}</p>
                <p>{founder.bio}</p>
              </article>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <script>
    const enterButton = document.querySelector(".landing-enter");
    const landingScreen = document.querySelector(".landing-screen");
    const body = document.body;

    const enterSite = () => {
      body.classList.add("site-entered");
      window.setTimeout(() => {
        landingScreen?.setAttribute("hidden", "");
      }, 700);
    };

    enterButton?.addEventListener("click", enterSite);

    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)");

    const experienceItems = Array.from(
      document.querySelectorAll<HTMLElement>(".experience-item"),
    );

    const revealAllExperienceItems = () => {
      for (const item of experienceItems) {
        item.classList.add("is-visible");
      }
    };

    if (experienceItems.length > 0) {
      if (reduceMotion.matches || !("IntersectionObserver" in window)) {
        revealAllExperienceItems();
      } else {
        const experienceObserver = new IntersectionObserver(
          (entries, observer) => {
            for (const entry of entries) {
              if (!entry.isIntersecting) continue;
              entry.target.classList.add("is-visible");
              observer.unobserve(entry.target);
            }
          },
          { threshold: 0.22, rootMargin: "0px 0px -8% 0px" },
        );

        experienceItems.forEach((item, index) => {
          item.style.transitionDelay = `${Math.min(index * 90, 300)}ms`;
          experienceObserver.observe(item);
        });

        reduceMotion.addEventListener("change", () => {
          if (!reduceMotion.matches) return;
          experienceObserver.disconnect();
          revealAllExperienceItems();
        });
      }
    }
  </script>
</BaseLayout>

<style>
  :global(body) {
    background: #000;
  }

  :global(body:not(.site-entered)) {
    overflow: hidden;
  }

  :global(body:not(.site-entered) .site-chrome),
  :global(body:not(.site-entered) .site-footer),
  :global(body:not(.site-entered) .section-dots),
  :global(body:not(.site-entered) .home-section),
  :global(body:not(.site-entered) .research-section),
  :global(body:not(.site-entered) .content-section) {
    opacity: 0;
    pointer-events: none;
  }

  :global(body.site-entered .site-chrome),
  :global(body.site-entered .site-footer),
  :global(body.site-entered .section-dots),
  :global(body.site-entered .home-section),
  :global(body.site-entered .research-section),
  :global(body.site-entered .content-section) {
    opacity: 1;
  }

  .landing-screen {
    position: fixed;
    inset: 0;
    z-index: 20;
    display: grid;
    place-items: center;
    overflow: hidden;
    background: #000;
    color: #fff;
    padding: clamp(2rem, 5vw, 4rem);
    transition:
      opacity 700ms ease,
      visibility 700ms ease;
  }

  :global(body.site-entered) .landing-screen {
    visibility: hidden;
    opacity: 0;
    pointer-events: none;
  }

  .landing-content {
    display: flex;
    width: min(100%, 58rem);
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .landing-title,
  .landing-rule,
  .landing-primary,
  .landing-secondary,
  .landing-enter {
    animation: landing-reveal 900ms ease-out both;
  }

  .landing-title {
    margin: 0;
    color: #f8f8f8;
    font-family: Inconsolata, monospace;
    font-size: clamp(3.8rem, 13vw, 8.5rem);
    font-weight: 900;
    letter-spacing: 0;
    line-height: 0.78;
  }

  .landing-rule {
    width: min(7.5rem, 28vw);
    height: 1px;
    margin-top: clamp(2.8rem, 6vw, 4rem);
    background: linear-gradient(90deg, transparent, #444, transparent);
    animation-delay: 180ms;
  }

  .landing-primary {
    max-width: 56rem;
    margin: clamp(2.5rem, 5.5vw, 4.2rem) 0 0;
    color: #777;
    font-family: Inconsolata, monospace;
    font-size: clamp(1rem, 1.8vw, 1.25rem);
    font-weight: 500;
    letter-spacing: 0.32em;
    line-height: 1.9;
    text-transform: uppercase;
    animation-delay: 320ms;
  }

  .landing-secondary {
    margin: clamp(1.2rem, 3vw, 1.6rem) 0 0;
    color: #515151;
    font-family: Inconsolata, monospace;
    font-size: clamp(0.82rem, 1.35vw, 1rem);
    font-weight: 500;
    letter-spacing: 0.35em;
    line-height: 1.75;
    text-transform: uppercase;
    animation-delay: 460ms;
  }

  .landing-domain {
    margin: clamp(1.4rem, 3vw, 1.9rem) 0 0;
    color: #151515;
    font-family: Inconsolata, monospace;
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.28em;
    line-height: 1;
    animation-delay: 600ms;
  }

  .landing-enter {
    border: 0;
    margin-top: clamp(1.4rem, 3vw, 1.8rem);
    background: transparent;
    color: #8d8d8d;
    cursor: pointer;
    font-family: Inconsolata, monospace;
    font-size: clamp(0.88rem, 1.4vw, 1rem);
    font-weight: 600;
    letter-spacing: 0.35em;
    line-height: 1;
    text-transform: uppercase;
    transition:
      color 180ms ease,
      transform 180ms ease;
    animation-delay: 740ms;
  }

  .home-section {
    position: relative;
    display: grid;
    min-height: calc(100svh - 3rem);
    overflow: hidden;
    place-items: center;
    scroll-margin-top: 0;
    background: #000;
    color: #5f6070;
    padding: clamp(4rem, 8vw, 6.5rem) 0 clamp(5.5rem, 10vw, 8rem);
    transition: opacity 700ms ease;
  }

  .hero-content {
    position: relative;
    z-index: 1;
    width: var(--site-column);
    margin: 0 auto;
    text-align: center;
  }

  .hero-kicker,
  .hero-subtitle,
  .hero-action,
  .scroll-cue {
    font-family: Inconsolata, monospace;
    font-weight: 700;
    letter-spacing: 0.35em;
    line-height: 1.3;
    text-transform: uppercase;
  }

  .hero-kicker {
    margin: 0;
    color: #8b5cf6;
    font-size: clamp(0.78rem, 1.35vw, 1.1rem);
  }

  .hero-title {
    display: inline-block;
    margin: clamp(1.6rem, 3.5vw, 2.4rem) 0 0;
    background: linear-gradient(100deg, #8791ff 7%, #5ea1f2 48%, #17bfd1 92%);
    background-clip: text;
    color: transparent;
    font-family: Inconsolata, monospace;
    font-size: clamp(5rem, 14vw, 9.2rem);
    font-weight: 900;
    letter-spacing: 0;
    line-height: 0.95;
    padding-bottom: 0.08em;
  }

  .hero-subtitle {
    margin: clamp(2.1rem, 4vw, 3rem) 0 0;
    color: #787789;
    font-size: clamp(0.9rem, 1.5vw, 1.18rem);
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: clamp(0.9rem, 2vw, 1.4rem);
    margin-top: clamp(2.4rem, 5vw, 3.4rem);
  }

  .hero-action {
    display: inline-flex;
    min-width: min(100%, 10.8rem);
    align-items: center;
    justify-content: center;
    border: 1px solid #31294d;
    border-radius: 4px;
    color: #868393;
    font-size: clamp(0.78rem, 1.15vw, 0.98rem);
    min-height: 3rem;
    padding: 0.88rem 1.55rem;
    text-decoration: none;
    transition:
      border-color 180ms ease,
      background-color 180ms ease,
      color 180ms ease,
      transform 180ms ease;
  }

  .hero-action:hover,
  .hero-action:focus-visible {
    color: #fff;
    transform: translateY(-2px);
  }

  .hero-action:focus-visible,
  .scroll-cue:focus-visible {
    outline: 1px solid #8b5cf6;
    outline-offset: 0.35rem;
  }

  .hero-action-primary {
    border-color: #8b5cf6;
    background: #8b5cf6;
    color: #fff;
  }

  .hero-action-secondary:hover,
  .hero-action-secondary:focus-visible {
    border-color: #6d5f91;
    background: #100d1b;
  }

  .scroll-cue {
    position: absolute;
    bottom: clamp(1.6rem, 4vw, 2.6rem);
    left: 50%;
    z-index: 1;
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: 0.45rem;
    color: #242332;
    font-size: clamp(0.72rem, 1vw, 0.9rem);
    text-decoration: none;
    transform: translateX(-50%);
    transition: color 180ms ease;
  }

  .scroll-cue:hover,
  .scroll-cue:focus-visible {
    color: #5d586f;
  }

  .content-section p {
    width: var(--site-column);
    margin: 0;
    font-family: Inconsolata, monospace;
    font-size: clamp(1rem, 1.8vw, 1.25rem);
    line-height: 1.7;
  }

  .about-section {
    min-height: 100svh;
    background:
      radial-gradient(
        circle at 5% 45%,
        rgba(139, 92, 246, 0.2),
        transparent 35rem
      ),
      radial-gradient(
        circle at 95% 35%,
        rgba(30, 90, 228, 0.12),
        transparent 24rem
      ),
      #04050f;
    color: #5f6070;
    padding: clamp(4.5rem, 8vw, 6.8rem) 0;
    scroll-margin-top: 4rem;
    transition: opacity 700ms ease;
  }

  .about-shell {
    width: var(--site-column);
    margin: 0 auto;
  }

  .about-kicker {
    margin: 0;
    color: #8b5cf6;
    font-family: Inconsolata, monospace;
    font-size: clamp(0.9rem, 1.3vw, 1.12rem);
    font-weight: 800;
    letter-spacing: 0.35em;
    line-height: 1.3;
    text-transform: uppercase;
  }

  .about-content {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: clamp(2.2rem, 4.8vw, 4.4rem);
    align-items: flex-start;
    margin-top: clamp(2.2rem, 4vw, 3.2rem);
  }

  .about-image-wrapper {
    position: relative;
    width: clamp(16.5rem, 28vw, 22rem);
    aspect-ratio: 1;
    border: 1px solid #161837;
    border-radius: 12px;
    background: #05061a;
    overflow: hidden;
    box-shadow: 0 0 0 1px rgba(96, 75, 167, 0.22);
  }

  .about-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 16%;
  }

  .about-text {
    display: flex;
    flex-direction: column;
    gap: clamp(1.2rem, 2.1vw, 1.8rem);
  }

  .about-title {
    margin: clamp(1.2rem, 2.8vw, 2rem) 0 0;
    color: #e7e8f1;
    font-family: Inconsolata, monospace;
    font-size: clamp(3.3rem, 8vw, 5.7rem);
    font-weight: 800;
    letter-spacing: 0;
    line-height: 0.95;
  }

  .about-paragraph {
    margin: 0;
    max-width: 38rem;
    color: #87879b;
    font-family: Inconsolata, monospace;
    font-size: clamp(1rem, 1.6vw, 1.24rem);
    font-weight: 600;
    line-height: 1.55;
  }

  .about-paragraph-lead {
    color: #d7d8e5;
  }

  .about-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
    margin-top: 0.3rem;
  }

  .about-tags span {
    border: 1px solid #1b1f44;
    border-radius: 999px;
    background: rgba(17, 19, 47, 0.78);
    color: #8587a2;
    font-family: Inconsolata, monospace;
    font-size: clamp(0.95rem, 1.2vw, 1.1rem);
    font-weight: 600;
    line-height: 1;
    padding: 0.65rem 1rem;
    cursor: default;
    transition:
