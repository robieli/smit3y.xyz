---
import BaseLayout from "../layouts/BaseLayout.astro";
import { loadResearchEntries } from "../lib/research";
import smit3yImage from "../assets/smit3y.jpg";
import LetterGlitch from "../components/LetterGlitchWaves.tsx";

const researchEntries = loadResearchEntries();
const featuredResearchEntries = researchEntries.slice(0, 6);
const experienceEntries = [
  {
    period: "PRESENT",
    role: "Sales, Trading & Prime Brokerage Intern",
    organization: "Coinbase",
    bullets: [
      "Working closely on navigating sales, custodial, and staking requests from clients inspired to get involved with the digital asset space",
    ],
  },
  {
    period: "SUMMER 2025",
    role: "Wealth Management Intern",
    organization: "Dyer Wealth Management - San Diego, CA",
    bullets: [
      "Assisted in portfolio construction, backtesting financial models and algorithms, and client advisory across equity and fixed-income allocations.",
    ],
  },
  {
    period: "2023 - PRESENT",
    role: "Practice Player",
    organization: "University of Michigan Women's Basketball",
    bullets: [
      "Selected as a practice player to train with the University of Michigan's Division I basketball team, making me a further fan of the WNBA and women's college basketball",
    ],
  },
  {
    period: "2023 - PRESENT",
    role: "Co-Founder",
    organization: "S&Y Scholars - College Consulting",
    bullets: [
      "Co-founded a peer-to-peer college admissions consulting service helping families navigate recruitment and strategy.",
      "Read more on how you can use our services below",
      "Winner of the 2023 New York Times College Essay Challenge",
    ],
  },
  {
    period: "ONGOING",
    role: "Independent Equity Research Analyst",
    organization: "Self-Directed Research",
    bullets: [
      "Published investment theses covering crypto mining, SaaS, DeFi, and semiconductor sectors",
      "Built financial models (DCF, comps, scenario analysis) for public equities and digital assets",
      "Participated in the 2026 Perplexity Computer Student Stock Pitch Competition with a long thesis",
    ],
  },
];
const snyStats = [
  { value: "37", label: "Schools Applied" },
  { value: "75%+", label: "Success Rate" },
  { value: "1570", label: "Combined SAT" },
  { value: "4.7", label: "Combined GPA" },
];
const snyServices = [
  {
    title: "Interview & Resume Guidance",
    description:
      "Real-time consultation leveraging our personal experiences. Personalized strategy tailored to each student's aspirations.",
    icon: "microphone",
  },
  {
    title: "Essay Editing",
    description:
      "Refining application essays to showcase your unique strengths. We translate your voice directly onto paper.",
    icon: "pen",
  },
  {
    title: "Application Strategy",
    description:
      "Expert advice on school selection, timelines, and standing out. We applied to 37 schools between us.",
    icon: "target",
  },
];
const snyFounders = [
  {
    name: "Samuel Smith",
    school: "University of Michigan - Economics & Psychology",
    bio: "Junior at U of M, practice player on the Women's Basketball team, avid chess player, and winner of the 2023 New York Times College Essay Challenge. Currently interning at a local wealth management firm in San Diego.",
  },
  {
    name: "Richard Yoon",
    school: "Columbia University - Dual Degree with Sciences Po",
    bio: "Junior at Columbia, spent first two years in Reims, France through the dual-degree program. Avid basketball player, 10+ years of robotics experience, and former Co-President of Mock Trial at La Jolla High.",
  },
];
---

<BaseLayout title="smit3y.xyz" fullBleed={true}>
  <section id="home" class="home-section" aria-label="Home">
    <div class="hero-backdrop" aria-hidden="true">
      <LetterGlitch
        client:load
        glitchSpeed={50}
        centerVignette={false}
        outerVignette={false}
        smooth={true}
        waveCurvature={50}
        waveWavelength={1400}
        waveBandThickness={200}
        waveAngleDeg={55}
      />
      <div class="hero-fade-bottom"></div>
    </div>
    <div class="hero-content">
      <h1 class="hero-title">SMIT3Y.XYZ</h1>
      <div class="hero-actions" aria-label="Featured actions">
        <a class="hero-action hero-action-primary" href="#research">
          VIEW RESEARCH <span aria-hidden="true">→</span>
        </a>
        <a class="hero-action hero-action-secondary" href="#about">ABOUT ME</a>
      </div>
    </div>
    <a class="scroll-cue" href="#about" aria-label="Scroll to about section">
      <span>SCROLL TO EXPLORE</span>
      <span aria-hidden="true">⌄</span>
    </a>
  </section>
  <section id="about" class="about-section" aria-label="About">
    <div class="about-shell">
      <p class="about-kicker">// ABOUT</p>
      <h2 class="about-title">Who I Am</h2>
      <div class="about-content">
        <div class="about-aside">
          <div class="about-image-wrapper">
            <img src={smit3yImage.src} alt="Eli Robinson" class="about-image" />
          </div>
          <div class="about-extras">
            <p class="about-snapshot">Here is a snapshot of who I am:</p>
            <div class="about-tags" aria-label="Focus areas">
              <span>Equity Research</span>
              <span>Bitcoin Mining</span>
              <span>DeFi & Blockchain</span>
              <span>SaaS Valuations</span>
              <span>Financial Modeling</span>
              <span>Quantitative Finance</span>
            </div>
          </div>
        </div>
        <div class="about-text">
          <p class="about-paragraph about-paragraph-lead">
            I am a builder, basketball player, and researcher based out of New
            York City.
          </p>
          <p class="about-paragraph">
            My passion lies in studying digital assets, macro trends, finding
            gems amongst equities, and debating with friends about our
            ever-moving world.
          </p>
          <p class="about-paragraph">
            I study Economics and Psychology at the University of Michigan,
            Class of 2027.
          </p>
          <p class="about-paragraph">
            I have lived in San Diego (where I am from) — Cairo, Egypt —
            Singapore — Chengdu, China — and Ann Arbor, Michigan.
          </p>
          <p class="about-paragraph">
            I am an avid Cavaliers fan, an annoying Michigan sports fan, an
            enormous Chinatown eater, a bigger podcast listener, and an aspiring
            runner.
          </p>
          <p class="about-paragraph">
            Doing research is what I find joy in, and participating in the most
            competitive probability game known as the United States Capital
            Markets is what I find myself doing most of the week.
          </p>
          <p class="about-paragraph">
            My close friends call me Smitty, and that is where I have derived
            the name for this website.
          </p>
        </div>
      </div>
    </div>
  </section>
  <section id="research" class="research-section" aria-label="Research">
    <div class="research-header">
      <p class="section-kicker">// RESEARCH</p>
      <h2>Investment Theses</h2>
      <p>
        I like to research beaten-down equities, trends I believe in and am
        invested in, digital assets, and decentralized finance. My work is
        published below:
      </p>
    </div>
    <div class="research-grid">
      {
        featuredResearchEntries.map((entry) => (
          <a class="research-card" href={`/research/${entry.slug}`}>
            <span class="research-card-label">
              {entry.stockLabel || entry.title.split(" ")[0]}
            </span>
            <span class="research-card-title">{entry.title}</span>
            <span class="research-card-arrow" aria-hidden="true">
              →
            </span>
          </a>
        ))
      }
    </div>
    <div class="research-actions">
      <a class="research-see-all" href="/research">See All</a>
    </div>
  </section>
  <section id="experience" class="experience-section" aria-label="Experience">
    <div class="experience-shell">
      <div class="experience-header">
        <p class="section-kicker">// EXPERIENCE</p>
        <h2>Where I've Worked</h2>
      </div>
      <div class="experience-timeline">
        {
          experienceEntries.map((entry) => (
            <article class="experience-item">
              <p class="experience-period">{entry.period}</p>
              <h3 class="experience-role">{entry.role}</h3>
              {entry.organization && (
                <p class="experience-organization">{entry.organization}</p>
              )}
              <ul class="experience-points">
                {entry.bullets.map((point) => (
                  <li>{point}</li>
                ))}
              </ul>
            </article>
          ))
        }
      </div>
    </div>
  </section>
  <section id="sny" class="sny-section" aria-label="S and Y Scholars">
    <div class="sny-shell">
      <header class="sny-header">
        <h2>S&amp;Y Scholars</h2>
        <p>
          Guidance from students who were in your shoes yesterday. Peer-to-peer
          college admissions consulting.
        </p>
      </header>

      <div class="sny-stats" aria-label="S and Y Scholars results">
        {
          snyStats.map((stat) => (
            <article class="sny-stat-card">
              <p class="sny-stat-value">{stat.value}</p>
              <p class="sny-stat-label">{stat.label}</p>
            </article>
          ))
        }
      </div>

      <div class="sny-services">
        <p class="section-kicker">// SERVICES</p>
        <h3>What We Offer</h3>
        <div class="sny-services-grid">
          {
            snyServices.map((service) => (
              <article class="sny-service-card">
                <span class="sny-service-icon" aria-hidden="true">
                  {service.icon === "microphone" && (
                    <svg viewBox="0 0 24 24" fill="none" focusable="false">
                      <path
                        d="M12 3a3 3 0 0 1 3 3v5a3 3 0 1 1-6 0V6a3 3 0 0 1 3-3Z"
                        stroke="currentColor"
                        stroke-width="1.8"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                      <path
                        d="M6.5 10.5a5.5 5.5 0 0 0 11 0M12 16v4M9 20h6"
                        stroke="currentColor"
                        stroke-width="1.8"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                    </svg>
                  )}
                  {service.icon === "pen" && (
                    <svg viewBox="0 0 24 24" fill="none" focusable="false">
                      <path
                        d="m4 20 4-1 10-10-3-3L5 16l-1 4Z"
                        stroke="currentColor"
                        stroke-width="1.8"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                      <path
                        d="m13 6 3 3M4 20l4-4"
                        stroke="currentColor"
                        stroke-width="1.8"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                    </svg>
                  )}
                  {service.icon === "target" && (
                    <svg viewBox="0 0 24 24" fill="none" focusable="false">
                      <circle
                        cx="12"
                        cy="12"
                        r="8"
                        stroke="currentColor"
                        stroke-width="1.8"
                      />
                      <circle
                        cx="12"
                        cy="12"
                        r="4"
                        stroke="currentColor"
                        stroke-width="1.8"
                      />
                      <circle cx="12" cy="12" r="1.2" fill="currentColor" />
                    </svg>
                  )}
                </span>
                <h4>{service.title}</h4>
                <p>{service.description}</p>
              </article>
            ))
          }
        </div>
      </div>

      <div class="sny-team">
        <p class="section-kicker">// TEAM</p>
        <h3>Meet the Founders</h3>
        <div class="sny-founders-grid">
          {
            snyFounders.map((founder) => (
              <article class="sny-founder-card">
                <h4>{founder.name}</h4>
                <p class="sny-founder-school">{founder.school}</p>
                <p>{founder.bio}</p>
              </article>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <script>
    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)");

    const experienceItems = Array.from(
      document.querySelectorAll<HTMLElement>(".experience-item"),
    );

    const revealAllExperienceItems = () => {
      for (const item of experienceItems) {
        item.classList.add("is-visible");
      }
    };

    if (experienceItems.length > 0) {
      if (reduceMotion.matches || !("IntersectionObserver" in window)) {
        revealAllExperienceItems();
      } else {
        const experienceObserver = new IntersectionObserver(
          (entries, observer) => {
            for (const entry of entries) {
              if (!entry.isIntersecting) continue;
              entry.target.classList.add("is-visible");
              observer.unobserve(entry.target);
            }
          },
          { threshold: 0.22, rootMargin: "0px 0px -8% 0px" },
        );

        experienceItems.forEach((item, index) => {
          item.style.transitionDelay = `${Math.min(index * 90, 300)}ms`;
          experienceObserver.observe(item);
        });

        reduceMotion.addEventListener("change", () => {
          if (!reduceMotion.matches) return;
          experienceObserver.disconnect();
          revealAllExperienceItems();
        });
      }
    }
  </script>
</BaseLayout>

<style>
  :global(body) {
    background:
      radial-gradient(circle at 12% 12%, var(--glow-6), transparent 32rem),
      radial-gradient(circle at 90% 8%, var(--glow-7), transparent 34rem),
      radial-gradient(circle at 6% 32%, var(--glow-1), transparent 36rem),
      radial-gradient(circle at 92% 52%, var(--glow-4), transparent 32rem),
      radial-gradient(circle at 50% 78%, var(--glow-5), transparent 30rem),
      var(--bg-1);
  }

  .home-section {
    position: relative;
    display: grid;
    min-height: calc(100svh - 3rem);
    overflow: hidden;
    place-items: center;
    scroll-margin-top: 0;
    background: transparent;
    color: var(--text-dim);
    padding: clamp(4rem, 8vw, 6.5rem) 0 clamp(5.5rem, 10vw, 8rem);
    transition: opacity 700ms ease;
  }

  .hero-backdrop {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    z-index: 0;
    background: var(--bg-glitch);
  }

  .hero-fade-bottom {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: linear-gradient(
      to bottom,
      transparent 0%,
      transparent 55%,
      var(--hero-fade-color) 100%
    );
    z-index: 1;
  }

  .hero-content {
    position: relative;
    z-index: 1;
    width: var(--site-column);
    margin: 0 auto;
    text-align: center;
  }

  .hero-action,
  .scroll-cue {
    font-family: Inconsolata, monospace;
    font-weight: 700;
    letter-spacing: 0.35em;
    line-height: 1.3;
    text-transform: uppercase;
  }

  .hero-title {
    display: inline-block;
    margin: clamp(1.6rem, 3.5vw, 2.4rem) 0 0;
    background: var(--gradient-hero);
    background-clip: text;
    color: transparent;
    font-family: Inconsolata, monospace;
    font-size: clamp(5rem, 14vw, 9.2rem);
    font-weight: 900;
    letter-spacing: 0;
    line-height: 0.95;
    padding-bottom: 0.08em;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: clamp(0.9rem, 2vw, 1.4rem);
    margin-top: clamp(2.4rem, 5vw, 3.4rem);
  }

  .hero-action {
    display: inline-flex;
    min-width: min(100%, 10.8rem);
    align-items: center;
    justify-content: center;
    border: 1px solid var(--border-6);
    border-radius: 4px;
    color: var(--text-hero-action);
    font-size: clamp(0.78rem, 1.15vw, 0.98rem);
    min-height: 3rem;
    padding: 0.88rem 1.55rem;
    text-decoration: none;
    transition:
      border-color 180ms ease,
      background-color 180ms ease,
      color 180ms ease,
      transform 180ms ease;
  }

  .hero-action:hover,
  .hero-action:focus-visible {
    color: var(--text-bright);
    transform: translateY(-2px);
  }

  .hero-action:focus-visible,
  .scroll-cue:focus-visible {
    outline: 1px solid var(--accent);
    outline-offset: 0.35rem;
  }

  .hero-action-primary {
    border-color: var(--accent);
    background: var(--accent);
    color: #fff;
  }

  .hero-action-secondary {
    background: var(--bg-glitch);
  }

  .hero-action-secondary:hover,
  .hero-action-secondary:focus-visible {
    border-color: var(--border-hero-hover);
    background: var(--bg-hero-hover);
  }

  .scroll-cue {
    position: absolute;
    bottom: clamp(1.6rem, 4vw, 2.6rem);
    left: 50%;
    z-index: 1;
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: 0.45rem;
    color: var(--text-cue);
    font-size: clamp(0.72rem, 1vw, 0.9rem);
    text-decoration: none;
    transform: translateX(-50%);
    transition: color 180ms ease;
  }

  .scroll-cue:hover,
  .scroll-cue:focus-visible {
    color: var(--text-cue-hover);
  }

  .content-section p {
    width: var(--site-column);
    margin: 0;
    font-family: Inconsolata, monospace;
    font-size: clamp(1rem, 1.8vw, 1.25rem);
    line-height: 1.7;
  }

  .about-section {
    position: relative;
    min-height: 100svh;
    background: transparent;
    color: var(--text-dim);
    padding: clamp(4.5rem, 8vw, 6.8rem) 0;
    scroll-margin-top: 4rem;
    transition: opacity 700ms ease;
  }

  .about-section::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 18rem;
    background: linear-gradient(to bottom, var(--bg-1), transparent);
    pointer-events: none;
    z-index: 0;
  }

  .about-shell {
    width: var(--site-column);
    margin: 0 auto;
  }

  .about-kicker {
    margin: 0;
    color: var(--accent);
    font-family: Inconsolata, monospace;
    font-size: clamp(0.9rem, 1.3vw, 1.12rem);
    font-weight: 800;
    letter-spacing: 0.35em;
    line-height: 1.3;
    text-transform: uppercase;
  }

  .about-content {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: clamp(2.2rem, 4.8vw, 4.4rem);
    align-items: flex-start;
    margin-top: clamp(2.2rem, 4vw, 3.2rem);
  }

  .about-aside {
    display: flex;
    flex-direction: column;
    gap: clamp(1.2rem, 2.1vw, 1.8rem);
    width: clamp(22rem, 34vw, 24rem);
  }

  .about-extras {
    display: flex;
    flex-direction: column;
    gap: clamp(1.2rem, 2.1vw, 1.8rem);
  }

  .about-image-wrapper {
    position: relative;
    width: clamp(16.5rem, 28vw, 22rem);
    aspect-ratio: 1;
    border: 1px solid var(--border-3);
    border-radius: 12px;
    background: var(--bg-img);
    overflow: hidden;
    box-shadow: 0 0 0 1px var(--border-img);
  }

  .about-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 16%;
  }

  .about-text {
    display: flex;
    flex-direction: column;
    gap: clamp(1.2rem, 2.1vw, 1.8rem);
  }

  .about-title {
    margin: clamp(1.2rem, 2.8vw, 2rem) 0 0;
    color: var(--text-heading);
    font-family: Inconsolata, monospace;
    font-size: clamp(3.3rem, 8vw, 5.7rem);
    font-weight: 800;
    letter-spacing: 0;
    line-height: 0.95;
  }

  .about-paragraph {
    margin: 0;
    max-width: 38rem;
    color: var(--text-sub);
    font-family: Inconsolata, monospace;
    font-size: clamp(1rem, 1.6vw, 1.24rem);
    font-weight: 600;
    line-height: 1.55;
  }

  .about-paragraph-lead {
    color: var(--text-lead);
  }

  .about-snapshot {
    margin: 0;
    color: var(--text-lead);
    font-family: Inconsolata, monospace;
    font-size: clamp(1rem, 1.6vw, 1.24rem);
    font-weight: 600;
    line-height: 1.55;
  }

  .about-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
    margin-top: 0.3rem;
  }

  .about-tags span {
    border: 1px solid var(--border-4);
    border-radius: 999px;
    background: var(--bg-tag);
    color: var(--text-sub);
    font-family: Inconsolata, monospace;
    font-size: clamp(0.95rem, 1.2vw, 1.1rem);
    font-weight: 600;
    line-height: 1;
    padding: 0.65rem 1rem;
    cursor: default;
    transition:
      transform 280ms cubic-bezier(0.34, 1.56, 0.64, 1),
      box-shadow 280ms ease,
      border-color 280ms ease,
      background-color 280ms ease,
      color 280ms ease;
    will-change: transform, box-shadow;
  }

  .about-tags span:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-tag);
    border-color: var(--border-tag-hover);
    background: var(--bg-tag-hover);
    color: var(--text-hover-tag);
  }

  .content-section {
    display: grid;
    min-height: 72svh;
    place-items: center;
    background: transparent;
    color: var(--text-dim);
    padding: clamp(3rem, 8vw, 6rem) 0;
    scroll-margin-top: 4rem;
    transition: opacity 700ms ease;
  }

  .research-section {
    min-height: 100svh;
    background: transparent;
    color: var(--text-body);
    padding: clamp(5rem, 9vw, 7rem) 0;
    scroll-margin-top: 4rem;
    transition: opacity 700ms ease;
  }

  .research-header,
  .research-grid {
    width: var(--site-column);
    margin: 0 auto;
  }

  .section-kicker {
    margin: 0;
    color: var(--accent);
    font-family: Inconsolata, monospace;
    font-size: clamp(0.9rem, 1.3vw, 1.12rem);
    font-weight: 800;
    letter-spacing: 0.35em;
    line-height: 1.3;
    text-transform: uppercase;
  }

  .research-header h2 {
    margin: clamp(1.2rem, 2.8vw, 2rem) 0 0;
    color: var(--text-title);
    font-family: Inconsolata, monospace;
    font-size: clamp(3.3rem, 8vw, 5.7rem);
    font-weight: 800;
    letter-spacing: 0;
    line-height: 0.95;
  }

  .research-header > p:last-child {
    margin: clamp(1.1rem, 2vw, 1.5rem) 0 0;
    color: var(--text-sub);
    font-family: Inconsolata, monospace;
    font-size: clamp(1rem, 1.6vw, 1.24rem);
    font-weight: 600;
    line-height: 1.55;
  }

  .research-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: clamp(1rem, 2vw, 1.35rem);
    margin-top: clamp(3rem, 6vw, 4.2rem);
  }

  .research-actions {
    width: var(--site-column);
    margin: clamp(1.6rem, 3vw, 2.2rem) auto 0;
    display: flex;
    justify-content: center;
  }

  .research-see-all {
    border: 1px solid var(--border-5);
    border-radius: 4px;
    color: var(--text-sub);
    font-family: Inconsolata, monospace;
    font-size: clamp(0.95rem, 1.25vw, 1.02rem);
    font-weight: 800;
    letter-spacing: 0.14em;
    line-height: 1;
    padding: 0.8rem 1.35rem;
    text-decoration: none;
    text-transform: uppercase;
    transition:
      border-color 180ms ease,
      color 180ms ease,
      background-color 180ms ease;
  }

  .research-see-all:hover,
