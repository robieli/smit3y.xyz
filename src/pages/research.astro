---
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  RESEARCH_PAGE_SIZE,
  getResearchPage,
  loadResearchEntries,
} from "../lib/research";

const entries = loadResearchEntries();
const { pageEntries, currentPage, totalPages } = getResearchPage(
  entries,
  1,
  RESEARCH_PAGE_SIZE,
);
const pageNumbers = Array.from({ length: totalPages }, (_, idx) => idx + 1);
const pageHref = (page: number) =>
  page === 1 ? "/research" : `/research/page/${page}`;
---

<BaseLayout title="Research | smit3y.xyz" fullBleed={true}>
  <section class="research-list-page">
    <header class="research-list-header">
      <p class="section-kicker">// RESEARCH</p>
      <h1>Investment Theses</h1>
      <p>
        Deep-dive fundamental analysis on publicly traded companies across
        crypto infrastructure, technology, and financial services.
      </p>
    </header>

    <div class="research-list-grid">
      {
        pageEntries.map((entry) => (
          <a class="research-list-card" href={`/research/${entry.slug}`}>
            <span class="research-card-label">
              {entry.stockLabel || entry.title.split(" ")[0]}
            </span>
            <span class="research-card-title">{entry.title}</span>
            {entry.summary && (
              <span class="research-card-summary">{entry.summary}</span>
            )}
            <span class="research-card-date">
              {entry.date
                ? new Date(entry.date).toLocaleDateString("en-US", {
                    month: "long",
                    year: "numeric",
                  })
                : "No upload date"}
            </span>
            <span class="research-card-arrow" aria-hidden="true">
              →
            </span>
          </a>
        ))
      }
    </div>

    {
      totalPages > 1 && (
        <nav class="research-pagination" aria-label="Research pagination">
          {pageNumbers.map((page) => (
            <a
              href={pageHref(page)}
              class:list={[page === currentPage && "is-active"]}
              aria-current={page === currentPage ? "page" : undefined}
            >
              {page}
            </a>
          ))}
        </nav>
      )
    }
  </section>
</BaseLayout>

<style>
  :global(body) {
    background: var(--bg-0);
  }

  .research-list-page {
    min-height: 100svh;
    background:
      radial-gradient(circle at 92% 8%, var(--glow-7), transparent 32rem),
      var(--bg-0);
    color: var(--text-body);
    padding: clamp(5rem, 9vw, 7rem) 0;
  }

  .research-list-header,
  .research-list-grid,
  .research-pagination {
    width: var(--site-column);
    margin: 0 auto;
  }

  .section-kicker {
    margin: 0;
    color: var(--accent);
    font-size: clamp(0.9rem, 1.3vw, 1.12rem);
    font-weight: 800;
    letter-spacing: 0.35em;
    line-height: 1.3;
    text-transform: uppercase;
  }

  .research-list-header h1 {
    margin: clamp(1.2rem, 2.8vw, 2rem) 0 0;
    color: var(--text-title);
    font-size: clamp(3.3rem, 8vw, 5.7rem);
    font-weight: 800;
    line-height: 0.95;
  }

  .research-list-header > p:last-child {
    max-width: 38rem;
    margin: clamp(1.1rem, 2vw, 1.5rem) 0 0;
    color: var(--text-sub);
    font-size: clamp(1rem, 1.6vw, 1.24rem);
    font-weight: 600;
    line-height: 1.55;
  }

  .research-list-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: clamp(1rem, 2vw, 1.35rem);
    margin-top: clamp(3rem, 6vw, 4.2rem);
  }

  .research-list-card {
    display: flex;
    min-height: 14rem;
    flex-direction: column;
    border: 1px solid var(--border-1);
    border-radius: 8px;
    background: var(--bg-card);
    color: inherit;
    padding: clamp(1.7rem, 3vw, 2.15rem);
    text-decoration: none;
    transition:
      border-color 180ms ease,
      background-color 180ms ease,
      transform 180ms ease;
  }

  .research-list-card:hover,
  .research-list-card:focus-visible {
    border-color: var(--border-6);
    background: var(--bg-card-hover);
    transform: translateY(-2px);
  }

  .research-list-card:focus-visible {
    outline: 1px solid var(--accent);
    outline-offset: 0.35rem;
  }

  .research-card-label {
    color: var(--accent-light);
    font-size: clamp(1.55rem, 2.7vw, 2rem);
    font-weight: 900;
    line-height: 1;
  }

  .research-card-title {
    margin-top: 1.35rem;
    color: var(--text-body);
    font-size: clamp(1rem, 1.5vw, 1.2rem);
    font-weight: 800;
    line-height: 1.35;
  }

  .research-card-summary {
    margin-top: 1rem;
    color: var(--text-sub);
    font-size: clamp(0.95rem, 1.35vw, 1.12rem);
    font-weight: 600;
    line-height: 1.4;
  }

  .research-card-date {
    margin-top: 1.5rem;
    color: var(--text-period);
    font-size: 0.95rem;
    font-weight: 700;
  }

  .research-card-arrow {
    align-self: flex-end;
    margin-top: auto;
    color: var(--accent);
    font-size: 1.1rem;
    font-weight: 900;
  }

  .research-pagination {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.65rem;
    margin-top: 2rem;
  }

  .research-pagination a {
    border: 1px solid var(--border-5);
    border-radius: 4px;
    color: var(--text-nav);
    font-size: 0.95rem;
    font-weight: 800;
    padding: 0.52rem 0.72rem;
    text-decoration: none;
  }

  .research-pagination a:hover,
  .research-pagination a:focus-visible,
  .research-pagination a.is-active {
    border-color: var(--accent);
    color: var(--accent-light);
  }

  @media (max-width: 700px) {
    .research-list-grid {
      grid-template-columns: 1fr;
    }

    .research-list-header h1 {
      font-size: clamp(2.8rem, 14vw, 4.2rem);
    }
  }
</style>
