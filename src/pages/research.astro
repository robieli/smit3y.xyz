---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getResearchPage, loadResearchEntries } from "../lib/research";

const entries = loadResearchEntries();
const { pageEntries, totalPages, currentPage } = getResearchPage(entries, 1);
const pageNumbers = Array.from({ length: totalPages }, (_, idx) => idx + 1);
const pageHref = (page: number) =>
  page === 1 ? "/research" : `/research/page/${page}`;
---

<BaseLayout title="Research | smit3y.xyz">
  <section class="space-y-6">
    <h1 class="text-3xl font-bold">Research</h1>
    {
      pageEntries.length > 0 ? (
        <ul class="space-y-4">
          {pageEntries.map((entry) => (
            <li>
              <a
                href={`/research/${entry.slug}`}
                class="research-entry-card block space-y-1 text-(--text) no-underline hover:text-(--text)"
              >
                <h2 class="text-xl font-semibold">{entry.title}</h2>
                <p class="text-sm text-(--muted)">
                  {entry.date
                    ? new Date(entry.date).toLocaleDateString("en-US")
                    : "No upload date"}
                </p>
                {entry.summary && <p class="text-(--muted)">{entry.summary}</p>}
              </a>
            </li>
          ))}
        </ul>
      ) : (
        <p class="text-(--muted)">
          No research articles have been published yet.
        </p>
      )
    }

    {
      totalPages > 1 && (
        <nav
          class="flex flex-wrap items-center justify-center gap-2 pt-2"
          aria-label="Research pagination"
        >
          {currentPage > 1 && (
            <a
              href={pageHref(currentPage - 1)}
              class="rounded border border-(--border) px-3 py-1 text-sm text-(--text) hover:border-(--accent) hover:text-(--accent)"
            >
              Prev
            </a>
          )}
          {pageNumbers.map((page) => (
            <a
              href={pageHref(page)}
              class:list={[
                "rounded border px-3 py-1 text-sm",
                page === currentPage
                  ? "border-(--accent) text-(--accent)"
                  : "border-(--border) text-(--text) hover:border-(--accent) hover:text-(--accent)",
              ]}
              aria-current={page === currentPage ? "page" : undefined}
            >
              {page}
            </a>
          ))}
          {currentPage < totalPages && (
            <a
              href={pageHref(currentPage + 1)}
              class="rounded border border-(--border) px-3 py-1 text-sm text-(--text) hover:border-(--accent) hover:text-(--accent)"
            >
              Next
            </a>
          )}
        </nav>
      )
    }
  </section>
</BaseLayout>
