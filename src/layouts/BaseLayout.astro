---
import Footer from "../components/Footer.astro";
import NavBar from "../components/NavBar.astro";
import "../styles/global.css";

interface Props {
  fullBleed?: boolean;
  showChrome?: boolean;
  title: string;
}

const { title, fullBleed = false, showChrome = true } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <script is:inline>
      (function () {
        var html = document.documentElement;
        var t = localStorage.getItem("theme");
        if (t === "light") html.setAttribute("data-theme", "light");
        else if (t !== "dark" && window.matchMedia("(prefers-color-scheme: light)").matches) {
          html.setAttribute("data-theme", "light");
        }
        var p = localStorage.getItem("palette");
        if (p && p !== "midnight") html.setAttribute("data-palette", p);
        if (p === "custom") {
          try {
            var c = JSON.parse(localStorage.getItem("custom-palette") || "{}");
            if (c.accent && c.g1 && c.g2 && c.g3) {
              var s = html.style;
              s.setProperty("--c-accent", c.accent);
              s.setProperty("--c-g1", c.g1);
              s.setProperty("--c-g2", c.g2);
              s.setProperty("--c-g3", c.g3);
            }
          } catch (e) {}
        }
      })();
    </script>
  </head>
  <body class="flex min-h-screen flex-col">
    {showChrome && <NavBar />}
    <main
      class={fullBleed
        ? "w-full flex-1"
        : "mx-auto w-full max-w-4xl flex-1 px-6 py-10"}
    >
      <slot />
    </main>
    {showChrome && <Footer />}
  </body>
</html>
